{
	"easycom": {
		"autoscan": true,
		"custom": {
			// uni-ui 规则如下配置
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line1/line1",
			"style": {
				"navigationBarTitleText": "1号线\nLine 1",
				"navigationBarBackgroundColor": "#F3D03E",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line1/xl2gzers",
			"style": {
				"navigationBarTitleText": "西塱——广州东站\nFrom Xilang to Guangzhou East Railway Station",
				"navigationBarBackgroundColor": "#F3D03E",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line2/line2",
			"style": {
				"navigationBarTitleText": "2号线\nLine 2",
				"navigationBarBackgroundColor": "#00629B",
				"navigationBarTextStyle": "white",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line2/jhwg2gzsrs",
			"style": {
				"navigationBarTitleText": "嘉禾望岗——广州南站\nFrom Jiahewanggang towards Guangzhou South Railway Station",
				"navigationBarBackgroundColor": "#00629B",
				"navigationBarTextStyle": "white",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line3/line3",
			"style": {
				"navigationBarTitleText": "3号线\nLine 3",
				"navigationBarBackgroundColor": "#ECA154",
				"navigationBarTextStyle": "white",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line3/B4/index",
			"style": {
				"navigationBarTitleText": "B4",
				"navigationBarBackgroundColor": "#ECA154",
				"navigationBarTextStyle": "white",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/line3/B4/apn2pys",
			"style": {
				"navigationBarTitleText": "机场北——番禺广场\nFrom Airport N. towards Panyu Square",
				"navigationBarBackgroundColor": "#ECA154",
				"navigationBarTextStyle": "white",
				"enablePullDownRefresh": false
			}
		},
		{
			"path" : "pages/line3/B4/apn2hb",
